modules = ["nodejs-24"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
BASE_PATH = "/"
API_PORT = "3001"

[workflows]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 20077
externalPort = 3002

[[ports]]
localPort = 20078
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=3001 node --enable-source-maps artifacts/api-server/dist/index.mjs & PORT=5000 BASE_PATH=/ pnpm --filter @workspace/realaize run serve"]
build = ["bash", "-c", "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/realaize run build && PORT=3001 pnpm --filter @workspace/api-server run build"]
