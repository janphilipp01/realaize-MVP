# Copy to .env.local and fill in real values. .env.local is gitignored.
# Both api-server and the realaize Vite dev server read from this file
# (when started with the appropriate loader / via direnv / shell export).

# ---- Login bypass (development) --------------------------------------------
# Set both flags to "true" to run the app without a login. Auth code stays in
# place and re-activates when the flags are removed. Run `pnpm seed:dev` once
# (in artifacts/api-server) to provision the fixed dev user + org these IDs
# point at. DEV_AUTH_ID / DEV_ORG_ID must match VITE_DEV_ORG_ID below.
# When the bypass is on, the SUPABASE_* / VITE_SUPABASE_* values are optional.
AUTH_DISABLED=false
# DEV_AUTH_ID=00000000-0000-0000-0000-000000000001
# DEV_ORG_ID=00000000-0000-0000-0000-000000000010
# DEV_EMAIL=dev@realaize.local

# ---- Backend-only (api-server) ---------------------------------------------

# Supabase Postgres connection string.
# Project Settings → Database → Connection String → URI.
# Recommend appending `?sslmode=require` for direct connections, or use
# pgbouncer/pooled URL for serverless deploys.
DATABASE_URL=postgres://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Supabase JWT secret (HS256). Project Settings → API → JWT Settings → JWT Secret.
# Used by the api-server to verify Bearer tokens locally without a JWKS roundtrip.
SUPABASE_JWT_SECRET=replace-with-jwt-secret

# Supabase Project URL. Project Settings → API → Project URL.
SUPABASE_URL=https://PROJECT_REF.supabase.co

# Service-role key (admin). Backend-only, NEVER expose to the frontend.
# Project Settings → API → service_role (secret). Used for trigger-driven
# tasks that need to bypass RLS (e.g. handle_new_auth_user, audit writes).
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Anthropic key for the AI proxy in /api/ai/*. Stays server-side.
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated CORS origins the api-server accepts (no spaces).
CORS_ORIGINS=http://localhost:5000,http://localhost:5001

# ---- Frontend (artifacts/realaize) -----------------------------------------
# Only VITE_-prefixed values are exposed to the browser bundle.

VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key
VITE_API_BASE_URL=http://localhost:3001

# Login bypass (frontend half). Must match AUTH_DISABLED / DEV_ORG_ID above.
VITE_AUTH_DISABLED=false
# VITE_DEV_ORG_ID=00000000-0000-0000-0000-000000000010
